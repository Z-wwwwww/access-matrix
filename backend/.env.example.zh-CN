# =============================================================================
# access-matrix 后端 (core-service) — 部署环境变量模板  ·  English: .env.example
# -----------------------------------------------------------------------------
# 复制为 `backend/.env` 并按你的环境填值。
#
# 重要：Spring Boot 不会自动加载 .env 文件。本文件只是给真正注入环境变量的
# 工具做参考：
#   - docker-compose:   env_file: ./backend/.env
#   - systemd:          EnvironmentFile=/path/to/.env
#   - kubernetes:       Secret / ConfigMap envFrom
#   - 裸 shell:         set -a; . ./backend/.env; set +a; java -jar ...
#
# 前端有自己的构建期 env（frontend/.env.*），与此无关。
#
# 分层：
#   [1] 必填    — 不设这些应用无法启动。
#   [2] 功能项  — 仅当用到该功能（邮件 / SSO）时才需要。
#   [3] (省略)  — 其余都在 application*.yml 里有合理默认值；
#                 有理由再覆盖，先读那里的注释。
#
# 标了 "# default: X" 的，是变量未设时 application.yml 的回退值。
# =============================================================================


# ── [1] 必填 — 不设无法启动 ─────────────────────────────────────────────────

# 生效的 Spring profile。不设 → "prod"（jwt 鉴权 + 租户隔离开启）。
# 开发用 "local"。（prod profile = application-prod.yml）
#SPRING_PROFILES_ACTIVE=prod

# Postgres — 应用数据库。保留 ?stringtype=unspecified：应用依赖它做
# jsonb / enum 绑定。
CORE_DB_URL=jdbc:postgresql://db-host:5432/access_matrix?stringtype=unspecified
CORE_DB_USERNAME=access_matrix
CORE_DB_PASSWORD=change-me

# Redis — 会话 / 限流 / 强制登出。注意：prod profile 走 TLS 连 Redis
# （spring.data.redis.ssl.enabled=true），所以生产的 Redis 必须支持 TLS。
CORE_REDIS_HOST=redis-host
#CORE_REDIS_PORT=6379          # default: 6379
#CORE_REDIS_PASSWORD=          # default: (无)
#CORE_REDIS_DB=0               # default: 0

# JWT 签名密钥 — 生产必须是强随机值（≥ 32 字节）。
# 生成：  openssl rand -base64 48
CORE_JWT_SECRET=

# 允许调用 API 的浏览器来源。逗号分隔，精确到 scheme+host（结尾不带 /）。
# 即 SPA 的对外地址。
CORE_CORS_ALLOWED_ORIGINS=https://app.yourco.com


# ── [2] 邮件 — 用到邀请 / 密码重置 / 开通流程则必填 ──────────────────────────
# 不设也能启动，但这些流程会静默不发邮件，被邀请的用户收不到设密码链接。
# 任何需要开通用户的真实部署都应启用。
CORE_MAIL_ENABLED=true
CORE_MAIL_HOST=smtp.yourprovider.com      # default: smtp.exmail.qq.com（腾讯企业邮）
#CORE_MAIL_PORT=465                        # default: 465（隐式 TLS；见 application.yml 说明）
CORE_MAIL_USERNAME=noreply@yourco.com      # 用于认证的完整邮箱地址
CORE_MAIL_PASSWORD=change-me               # SMTP / 客户端专用密码
CORE_MAIL_FROM=noreply@yourco.com          # default: noreply@localhost
#CORE_MAIL_FROM_NAME=Access Matrix         # default: Access Matrix
# 前端对外基址 — 用于在邮件里拼邀请 / 重置链接。
CORE_APP_BASE_URL=https://app.yourco.com   # default: http://localhost:5273


# ── [2] SSO / Keycloak — 仅 OIDC 模式才需要 ─────────────────────────────────
# 生产默认 JWT 模式（后端自签 HS256 token，不需要 Keycloak）。
# Keycloak/OIDC 是 opt-in；用 APP_SECURITY_MODE=oidc 打开（env 会覆盖
# prod yml 里的 `app.security.mode: jwt`）。
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ ⚠️  生产 KEYCLOAK 检查清单 — 别跳过（两项最容易忘）                          │
# │                                                                            │
# │ 1. 设一个强 CORE_KEYCLOAK_PROVISIONER_SECRET。                             │
# │    后端不是读 KC 生成的 secret，而是把这个值“推”进 Keycloak。所以强度由     │
# │    你负责。dev 默认值（`dev-provisioner-secret-change-in-prod`）是临时用的；│
# │    带去生产 = 一个 create-realm 服务账号挂着公开已知的密码。                │
# │    生成：  openssl rand -base64 32   → 存进 vault。                         │
# │                                                                            │
# │ 2. 首次成功启动后，删掉 bootstrap 的 root 凭据。                            │
# │    provisioner client 已持久化在 Keycloak 里。把一次性的 KC root admin      │
# │    （BOOTSTRAP_USERNAME/PASSWORD）继续留在 env 里，等于平白放着一个高权凭据。│
# │    一旦日志出现 `[kc-provisioner] provisioner ready`：                      │
# │        unset CORE_KEYCLOAK_BOOTSTRAP_USERNAME CORE_KEYCLOAK_BOOTSTRAP_PASSWORD
# │        set   CORE_KEYCLOAK_BOOTSTRAP_ENABLED=false                         │
# │    稳态：后端持有的唯一 KC 密钥就是第 1 项的 provisioner secret。           │
# └──────────────────────────────────────────────────────────────────────────┘
#
# 运行时：后端始终以专用 service-account client（client_credentials）调用
# Keycloak Admin API —— 一条路径，运行时没有 admin 密码。你只需设它的 secret：
#APP_SECURITY_MODE=oidc
#CORE_OIDC_ISSUER_BASE_URI=https://auth.yourco.com    # 多 realm 信任前缀（realm == 租户）
#CORE_KEYCLOAK_SERVER_URL=https://auth.yourco.com
# ⚠️ 第 1 项 — 生产必须是 vault 里的强 secret（不能用 dev 默认值）：
#CORE_KEYCLOAK_PROVISIONER_SECRET=                    # `openssl rand -base64 32`；运行时身份
#
# BOOTSTRAP（仅首次启动）：provisioner client 由 KeycloakProvisionerSeeder 在启动时
# 用一次性 admin 凭据自动创建 —— 无需手动操作 Keycloak 控制台。⚠️ 第 2 项 —
# 首次成功启动后删除 USERNAME/PASSWORD 并设 ENABLED=false（见上面的检查清单）。
# 详见 infra/keycloak/README.zh-CN.md（生产环境定型，“自动 bootstrap”）。
#CORE_KEYCLOAK_BOOTSTRAP_ENABLED=true
#CORE_KEYCLOAK_BOOTSTRAP_USERNAME=<一次性 KC root admin — 首次启动后删除>
#CORE_KEYCLOAK_BOOTSTRAP_PASSWORD=<一次性 KC root 密码 — 首次启动后删除>
#CORE_KEYCLOAK_BOOTSTRAP_MANAGED_REALMS=demo,system   # 既有 realm，授予其 manage-users
