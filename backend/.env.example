# =============================================================================
# access-matrix backend (core-service) — deployment environment template
# -----------------------------------------------------------------------------
# Copy to `backend/.env` and fill in the values for your environment.
#
# IMPORTANT: Spring Boot does NOT auto-load .env files. This file is a
# REFERENCE for whatever actually injects the environment:
#   - docker-compose:   env_file: ./backend/.env
#   - systemd:          EnvironmentFile=/path/to/.env
#   - kubernetes:       Secret / ConfigMap envFrom
#   - bare shell:       set -a; . ./backend/.env; set +a; java -jar ...
#
# The FRONTEND has its own build-time env under frontend/.env.* — unrelated.
#
# Tiers below:
#   [1] REQUIRED  — the app will NOT start without these.
#   [2] FEATURE   — required only if you use that feature (email / SSO).
#   [3] (omitted) — everything else has a sane default in application*.yml.
#                   Override only with a reason; read that file's comments.
#
# Defaults shown as "# default: X" are what application.yml falls back to when
# the var is unset.
# =============================================================================


# ── [1] REQUIRED — app won't boot without these ─────────────────────────────

# Active Spring profile. Unset → "prod" (jwt auth + tenant isolation ON).
# Use "local" for development. (prod profile = application-prod.yml)
#SPRING_PROFILES_ACTIVE=prod

# Postgres — the application database. Keep ?stringtype=unspecified: the app
# relies on it for jsonb / enum binding.
CORE_DB_URL=jdbc:postgresql://db-host:5432/access_matrix?stringtype=unspecified
CORE_DB_USERNAME=access_matrix
CORE_DB_PASSWORD=change-me

# Redis — sessions / rate-limit / force-logout. NOTE: the prod profile connects
# to Redis over TLS (spring.data.redis.ssl.enabled=true), so your Redis must
# terminate TLS in prod.
CORE_REDIS_HOST=redis-host
#CORE_REDIS_PORT=6379          # default: 6379
#CORE_REDIS_PASSWORD=          # default: (none)
#CORE_REDIS_DB=0               # default: 0

# JWT signing secret — MUST be a strong random value (>= 32 bytes) in prod.
# Generate one:  openssl rand -base64 48
CORE_JWT_SECRET=

# Browser origins allowed to call the API. Comma-separated, exact scheme+host
# (no trailing slash). This is the SPA's public URL(s).
CORE_CORS_ALLOWED_ORIGINS=https://app.yourco.com


# ── [2] EMAIL — required if you use invites / password reset / onboarding ────
# Without these the app still BOOTS, but those flows silently send no mail, so
# invited users never receive their set-password link. Enable for any real
# deployment that onboards users.
CORE_MAIL_ENABLED=true
CORE_MAIL_HOST=smtp.yourprovider.com      # default: smtp.exmail.qq.com (Tencent ExMail)
#CORE_MAIL_PORT=465                        # default: 465 (implicit TLS; see application.yml notes)
CORE_MAIL_USERNAME=noreply@yourco.com      # the FULL email address used to authenticate
CORE_MAIL_PASSWORD=change-me               # SMTP / client-specific password
CORE_MAIL_FROM=noreply@yourco.com          # default: noreply@localhost
#CORE_MAIL_FROM_NAME=Access Matrix         # default: Access Matrix
# Public base URL of the FRONTEND — used to build invite / reset links in emails.
CORE_APP_BASE_URL=https://app.yourco.com   # default: http://localhost:5273


# ── [2] SSO / Keycloak — required ONLY in OIDC mode ──────────────────────────
# Prod defaults to JWT mode (backend-signed HS256 tokens, NO Keycloak needed).
# Keycloak/OIDC is opt-in; turn it on with APP_SECURITY_MODE=oidc (env overrides
# the prod yml's `app.security.mode: jwt`).
#
# RUNTIME: the backend always talks to Keycloak's Admin API as a dedicated
# service-account client (client_credentials) — ONE path, no admin password at
# runtime. You only set its secret:
#APP_SECURITY_MODE=oidc
#CORE_OIDC_ISSUER_BASE_URI=https://auth.yourco.com    # multi-realm trust prefix (realm == tenant)
#CORE_KEYCLOAK_SERVER_URL=https://auth.yourco.com
#CORE_KEYCLOAK_PROVISIONER_SECRET=                    # strong secret from vault; the runtime identity
#
# BOOTSTRAP (first boot only): the provisioner client is auto-created at startup
# by KeycloakProvisionerSeeder using a ONE-TIME admin credential — no manual
# Keycloak console setup. After the first successful boot you can set
# CORE_KEYCLOAK_BOOTSTRAP_ENABLED=false and remove the bootstrap username/password.
# See infra/keycloak/README.md (Production posture, "auto-bootstrap").
#CORE_KEYCLOAK_BOOTSTRAP_ENABLED=true
#CORE_KEYCLOAK_BOOTSTRAP_USERNAME=<one-time KC root admin>
#CORE_KEYCLOAK_BOOTSTRAP_PASSWORD=<one-time KC root password>
#CORE_KEYCLOAK_BOOTSTRAP_MANAGED_REALMS=demo,system   # pre-existing realms to grant manage-users on
