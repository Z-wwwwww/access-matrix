# =============================================================================
# access-matrix バックエンド (core-service) — デプロイ用環境変数テンプレート
# English: .env.example  ·  中文: .env.example.zh-CN
# -----------------------------------------------------------------------------
# `backend/.env` にコピーし、環境ごとの値を記入してください。
#
# 重要: Spring Boot は .env ファイルを自動読み込みしません。本ファイルは環境変数を
# 実際に注入する仕組みのための参照です:
#   - docker-compose:   env_file: ./backend/.env
#   - systemd:          EnvironmentFile=/path/to/.env
#   - kubernetes:       Secret / ConfigMap envFrom
#   - 素の shell:       set -a; . ./backend/.env; set +a; java -jar ...
#
# フロントエンドはビルド時 env を frontend/.env.* に別途持ちます（無関係）。
#
# 階層:
#   [1] 必須    — 設定しないとアプリが起動しません。
#   [2] 機能別  — その機能（メール / SSO）を使う場合のみ必要。
#   [3] (省略)  — それ以外はすべて application*.yml に妥当な既定値あり。
#                 理由があるときだけ上書きを。まずそのコメントを読むこと。
#
# "# default: X" は、変数未設定時に application.yml が使う既定値です。
# =============================================================================


# ── [1] 必須 — 設定しないと起動しない ───────────────────────────────────────

# 有効な Spring プロファイル。未設定 → "prod"（jwt 認証 + テナント分離 ON）。
# 開発時は "local"。（prod プロファイル = application-prod.yml）
#SPRING_PROFILES_ACTIVE=prod

# Postgres — アプリ DB。?stringtype=unspecified は残すこと: jsonb / enum
# バインディングで依存しています。
CORE_DB_URL=jdbc:postgresql://db-host:5432/access_matrix?stringtype=unspecified
CORE_DB_USERNAME=access_matrix
CORE_DB_PASSWORD=change-me

# Redis — セッション / レート制限 / 強制ログアウト。注意: prod プロファイルは
# TLS で Redis に接続します（spring.data.redis.ssl.enabled=true）。本番の Redis は
# TLS 終端できる必要があります。
CORE_REDIS_HOST=redis-host
#CORE_REDIS_PORT=6379          # default: 6379
#CORE_REDIS_PASSWORD=          # default: (なし)
#CORE_REDIS_DB=0               # default: 0

# JWT 署名シークレット — 本番では強いランダム値（32 バイト以上）必須。
# 生成:  openssl rand -base64 48
CORE_JWT_SECRET=

# API を呼び出せるブラウザ origin。カンマ区切り、scheme+host を厳密に
# （末尾スラッシュなし）。SPA の公開 URL です。
CORE_CORS_ALLOWED_ORIGINS=https://app.yourco.com


# ── [2] メール — 招待 / パスワードリセット / オンボーディングを使うなら必須 ──
# 未設定でも起動はしますが、これらのフローはメールを送らず、招待されたユーザーは
# パスワード設定リンクを受け取れません。ユーザーをオンボードする本番では有効化を。
CORE_MAIL_ENABLED=true
CORE_MAIL_HOST=smtp.yourprovider.com      # default: smtp.exmail.qq.com（Tencent ExMail）
#CORE_MAIL_PORT=465                        # default: 465（暗黙 TLS。application.yml 参照）
CORE_MAIL_USERNAME=noreply@yourco.com      # 認証に使う完全なメールアドレス
CORE_MAIL_PASSWORD=change-me               # SMTP / クライアント専用パスワード
CORE_MAIL_FROM=noreply@yourco.com          # default: noreply@localhost
#CORE_MAIL_FROM_NAME=Access Matrix         # default: Access Matrix
# フロントエンドの公開ベース URL — メール内の招待 / リセットリンク生成に使用。
CORE_APP_BASE_URL=https://app.yourco.com   # default: http://localhost:5273


# ── [2] SSO / Keycloak — OIDC モードのときのみ必要 ──────────────────────────
# 本番は既定で JWT モード（バックエンド署名の HS256 トークン。Keycloak 不要）。
# Keycloak/OIDC はオプトイン。APP_SECURITY_MODE=oidc で有効化（env が prod yml の
# `app.security.mode: jwt` を上書きします）。
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ ⚠️  本番 KEYCLOAK チェックリスト — 飛ばさないこと（忘れやすい 2 点）         │
# │                                                                            │
# │ 1. 強い CORE_KEYCLOAK_PROVISIONER_SECRET を設定する。                      │
# │    バックエンドは KC 生成のシークレットを読むのではなく、この値を Keycloak  │
# │    へ「push」します。よって強度はあなたの責任です。dev 既定値              │
# │    （`dev-provisioner-secret-change-in-prod`）は使い捨て。本番に持ち込むと  │
# │    create-realm 権限のサービスアカウントに公知のパスワードが付く状態に。    │
# │    生成:  openssl rand -base64 32   → vault に保管。                        │
# │                                                                            │
# │ 2. 初回起動が成功したら、bootstrap の root 資格情報を削除する。            │
# │    provisioner クライアントは Keycloak に永続化済み。使い捨ての KC root     │
# │    admin（BOOTSTRAP_USERNAME/PASSWORD）を env に残すのは、強力な資格情報を   │
# │    無意味に放置するだけ。ログに                                            │
# │    `[kc-provisioner] provisioner ready` が出たら:                          │
# │        unset CORE_KEYCLOAK_BOOTSTRAP_USERNAME CORE_KEYCLOAK_BOOTSTRAP_PASSWORD
# │        set   CORE_KEYCLOAK_BOOTSTRAP_ENABLED=false                         │
# │    定常状態: バックエンドが持つ KC シークレットは項目 1 の provisioner      │
# │    secret のみ。                                                           │
# └──────────────────────────────────────────────────────────────────────────┘
#
# 実行時: バックエンドは常に専用のサービスアカウントクライアント
# （client_credentials）で Keycloak Admin API を呼びます — 経路は 1 本、実行時に
# admin パスワードは不要。設定するのはその secret だけ:
#APP_SECURITY_MODE=oidc
#CORE_OIDC_ISSUER_BASE_URI=https://auth.yourco.com    # マルチ realm 信頼プレフィックス（realm == テナント）
#CORE_KEYCLOAK_SERVER_URL=https://auth.yourco.com
# ⚠️ 項目 1 — 本番では vault の強い secret 必須（dev 既定値は不可）:
#CORE_KEYCLOAK_PROVISIONER_SECRET=                    # `openssl rand -base64 32`；実行時の身元
#
# BOOTSTRAP（初回起動のみ）: provisioner クライアントは KeycloakProvisionerSeeder が
# 起動時に使い捨ての admin 資格情報で自動作成します — Keycloak コンソールの手作業は
# 不要。⚠️ 項目 2 — 初回起動成功後に USERNAME/PASSWORD を削除し ENABLED=false に
# （上のチェックリスト参照）。
# 詳細は infra/keycloak/README.md（Production posture, "auto-bootstrap"）。
#CORE_KEYCLOAK_BOOTSTRAP_ENABLED=true
#CORE_KEYCLOAK_BOOTSTRAP_USERNAME=<使い捨ての KC root admin — 初回起動後に削除>
#CORE_KEYCLOAK_BOOTSTRAP_PASSWORD=<使い捨ての KC root パスワード — 初回起動後に削除>
#CORE_KEYCLOAK_BOOTSTRAP_MANAGED_REALMS=demo,system   # 既存 realm。manage-users を付与する対象
