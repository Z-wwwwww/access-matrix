# Root-level .gitignore — cross-stack only.
# Each stack maintains its own under backend/.gitignore and frontend/.gitignore
# (Maven targets / Node modules etc.) so the root stays small and language-neutral.

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr
.fleet/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor swap / backup
*.swp
*.swo
*~
.*.kate-swp

# Claude Code per-user override (skill prompts under .claude/commands/ stay committed)
.claude/settings.local.json
